datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  password        String
  role            String           @default("USER") // USER, ADMIN
  createdAt       DateTime         @default(now())
  
  resumes         Resume[]
  jobDescriptions JobDescription[]
  interviews      Interview[]
  usages          Usage[]
  subscription    Subscription?
  answers         Answer[]
}

model Resume {
  id        String           @id @default(cuid())
  userId    String
  name      String
  url       String
  fileKey   String
  rawText   String           @db.Text @default("")
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses  ResumeAnalysis[]
  atsAnalyses ATSAnalysis[]
  interviews Interview[]
}

model ResumeAnalysis {
  id             String   @id @default(cuid())
  resumeId       String
  skills         String[]
  experience     Json     @default("[]") // Structured experience
  education      Json     @default("[]") // Structured education
  projects       Json     @default("[]") // Structured projects
  certifications String[] @default([])
  summary        String   @db.Text
  createdAt      DateTime @default(now())

  resume         Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model JobDescription {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String        @db.Text
  createdAt   DateTime      @default(now())

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  atsAnalyses ATSAnalysis[]
  interviews  Interview[]
}

model ATSAnalysis {
  id               String         @id @default(cuid())
  resumeId         String
  jobDescriptionId String
  score            Int
  missingSkills    String[]
  strengthAreas    String[]
  improvementAreas String[]
  rawFeedback      String         @db.Text
  createdAt        DateTime       @default(now())

  resume           Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobDescription   JobDescription @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)
}

model Interview {
  id               String          @id @default(cuid())
  userId           String
  resumeId         String?
  jobDescriptionId String?
  jobTitle         String
  jobDescription   String          @db.Text
  interviewType    String          // TECHNICAL, BEHAVIORAL, HR, SYSTEM_DESIGN
  difficulty       String          @default("MEDIUM") // EASY, MEDIUM, HARD
  questionCount    Int             @default(5)
  status           String          @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  createdAt        DateTime        @default(now())

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume           Resume?         @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  jobDescriptionRef JobDescription? @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)
  questions        Question[]
  report           InterviewReport?
}

model Question {
  id          String   @id @default(cuid())
  interviewId String
  text        String   @db.Text
  category    String?
  order       Int
  type        String   @default("TEXT") // TEXT, CODING
  codeTemplate String? @db.Text
  codeLanguage String?
  testCases   Json?    // Optional test cases for coding round
  createdAt   DateTime @default(now())

  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  answers     Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  userId     String
  text       String   @db.Text
  codeAnswer String?  @db.Text // Store code response for coding round
  duration   Int?     // in seconds
  evaluation Json?    // Per-answer evaluation report (detailed)
  createdAt  DateTime @default(now())

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterviewReport {
  id             String    @id @default(cuid())
  interviewId    String    @unique
  overallScore   Int
  summary        String    @db.Text
  strengths      String[]
  weaknesses     String[]
  recommendations String[]
  skillBreakdown Json      @default("{}") // Skill-by-skill metrics
  createdAt      DateTime  @db.Timestamp(6) @default(now())

  interview      Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model Usage {
  id        String   @id @default(cuid())
  userId    String
  type      String
  count     Int      @default(1)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  plan            String    @default("FREE") // FREE, PRO
  status          String    @default("ACTIVE")
  currentPeriodEnd DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
