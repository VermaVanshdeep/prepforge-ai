# Database connection string (PostgreSQL via Supabase, Neon, or Railway)
DATABASE_URL="postgresql://user:password@host:port/database"

# NextAuth Configuration
# Run `npx auth secret` or `openssl rand -base64 32` to generate a secret
AUTH_SECRET="your_generated_secret_here"
# Only required in development. In production (Vercel), this is automatically detected.
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth Credentials
# Obtain these from the Google Cloud Console (APIs & Services -> Credentials)
AUTH_GOOGLE_ID="your_google_oauth_client_id"
AUTH_GOOGLE_SECRET="your_google_oauth_client_secret"

# UploadThing Credentials (for Resume Parsing)
UPLOADTHING_SECRET="your_uploadthing_secret"
UPLOADTHING_APP_ID="your_uploadthing_app_id"

# Gemini AI API Key (for Mock Interview Generation & Evaluation)
GEMINI_API_KEY="your_google_gemini_api_key"

# Groq API Key (for alternative LLM providers)
GROQ_API_KEY="your_groq_api_key_here"
